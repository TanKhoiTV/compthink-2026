{
  "tasks": {
    "start": "deno run --allow-net --allow-env server.ts",
    "dev": "deno run --allow-net --allow-env --watch server.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net server/*.test.ts",
    "lint": "deno lint"
  },
  "lint": {
    "rules": {
      "exclude": ["no-unused-vars"]
    }
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true
  }
}

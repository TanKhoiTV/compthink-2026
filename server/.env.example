# Postgres connection string. Thiếu biến này → server chạy chế độ KHÔNG DB.
# Đặt giá trị thật trong .env (đã .gitignore) hoặc secret của môi trường deploy (HF Space).
DATABASE_URL=postgres://user:password@host:5432/trekkopoly_db

# Secret ký token đăng nhập (HMAC). Đổi sang chuỗi ngẫu nhiên đủ dài khi deploy.
AUTH_SECRET=change-me-please
